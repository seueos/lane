# Copy to deploy/jetson.env and adjust for your board.
# Used by scripts/setup_jetson_device.sh and scripts/sync_to_jetson.sh

# SSH target (user@host or alias from ~/.ssh/config)
JETSON_HOST=jetson@192.168.1.100

# Remote install directory
JETSON_REMOTE_DIR=~/lane_tracking

# JetPack 6 ONNX wheel index (pick one that matches `nvcc --version` / JetPack)
# JP 6.0–6.1 (CUDA 12.2): https://pypi.jetson-ai-lab.io/jp6/cu122
# JP 6.2       (CUDA 12.6): https://pypi.jetson-ai-lab.io/jp6/cu126
# JP 6.2.1+    (CUDA 12.9): https://pypi.jetson-ai-lab.io/jp6/cu129
ONNX_INDEX_URL=https://pypi.jetson-ai-lab.io/jp6/cu126

# Python on Jetson (JetPack 6 ships 3.10)
JETSON_PYTHON=python3

# Default processing width on device (0 = full resolution)
JETSON_PROCESS_WIDTH=640
